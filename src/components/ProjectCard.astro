---
import Badge from './Badge.astro';

export interface Props {
  title: string;
  description: string;
  hoverColor?: string; // e.g., 'group-hover:text-cyan-400'
  colSpan?: boolean; // Set to true to span 2 columns on lg screens
  technologies: { text: string; theme?: string }[];
}

const { 
  title, 
  description, 
  hoverColor = "group-hover:text-cyan-400", 
  colSpan = false,
  technologies = []
} = Astro.props;
---

<div class={`glass-card flex flex-col p-6 rounded-2xl group ${colSpan ? 'lg:col-span-2' : ''}`}>
  <h3 class={`text-xl font-bold text-white mb-2 transition-colors ${hoverColor}`}>{title}</h3>
  <p class="text-slate-400 text-sm leading-relaxed flex-grow mb-6 max-w-3xl">
    {description}
  </p>
  <div class="flex flex-wrap gap-2 mt-auto">
    {technologies.map(tech => (
      <Badge text={tech.text} theme={tech.theme as any} />
    ))}
  </div>
</div>
