---
import '../styles/global.css';

import Navbar from '../components/Navbar.astro';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth bg-slate-950">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Ibrahim Nassar</title>
    <meta name="description" content={description} />
    <meta name="author" content="Ibrahim Nassar" />
    <link rel="canonical" href={Astro.url} />
    
    <!-- Google Fonts for Logo -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Grand+Hotel&display=swap" rel="stylesheet">
    
    <!-- Open Graph for Social Sharing -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
  </head>
  <body class="bg-slate-950 text-slate-300 font-sans antialiased selection:bg-cyan-500 selection:text-white flex flex-col min-h-screen">
    
    <Navbar />

    <main class="flex-grow w-full max-w-6xl mx-auto px-4 py-8 md:py-16">
      <slot />
    </main>

  </body>
</html>