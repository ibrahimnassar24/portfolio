---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<Layout title="Contact Me" description="Contact information and professional social links of Ibrahim Nassar.">
  
  <PageHeader 
    title="Let's"
    subtitleAccent="Connect"
    description="I'm currently based in Alexandria, Egypt, and I'm open to discussing full-stack web development and backend engineering opportunities globally."
    lineColor="bg-cyan-500"
    centered={true}
  />

  <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8 animate-fade-up" style="animation-delay: 100ms;">
    
    <!-- Email Card -->
    <a href="mailto:ebrahim24111990@gmail.com" class="glass-card flex flex-col items-center p-10 rounded-3xl group hover:-translate-y-1 hover:shadow-[0_10px_40px_-10px_rgba(6,182,212,0.3)] transition-all duration-300">
      <div class="w-16 h-16 mb-6 rounded-2xl bg-slate-800/80 flex items-center justify-center border border-slate-700/50 text-cyan-400 group-hover:bg-cyan-500/20 group-hover:text-cyan-300 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
        </svg>
      </div>
      <h3 class="text-xl font-bold text-white mb-2">Email Me</h3>
      <p class="text-slate-400 text-center font-medium group-hover:text-cyan-400 transition-colors">ebrahim24111990@gmail.com</p>
    </a>

    <!-- Phone Card -->
    <div class="glass-card flex flex-col items-center p-10 rounded-3xl group hover:-translate-y-1 transition-all duration-300 cursor-default">
      <div class="w-16 h-16 mb-6 rounded-2xl bg-slate-800/80 flex items-center justify-center border border-slate-700/50 text-emerald-400 group-hover:bg-emerald-500/20 group-hover:text-emerald-300 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-2.896-1.596-5.48-4.08-7.074-6.97l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
        </svg>
      </div>
      <h3 class="text-xl font-bold text-white mb-2">Call Me</h3>
      <p class="text-slate-400 text-center font-medium group-hover:text-emerald-400 transition-colors">+20 109 546 6271</p>
    </div>

    <!-- LinkedIn Card -->
    <a href="https://www.linkedin.com/in/ibrahim-nassar-5325ab236" target="_blank" rel="noopener noreferrer" class="glass-card flex flex-col items-center p-10 rounded-3xl group hover:-translate-y-1 hover:shadow-[0_10px_40px_-10px_rgba(99,102,241,0.3)] transition-all duration-300">
      <div class="w-16 h-16 mb-6 rounded-2xl bg-slate-800/80 flex items-center justify-center border border-slate-700/50 text-indigo-400 group-hover:bg-indigo-500/20 group-hover:text-indigo-300 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
          <rect x="2" y="9" width="4" height="12"></rect>
          <circle cx="4" cy="4" r="2"></circle>
        </svg>
      </div>
      <h3 class="text-xl font-bold text-white mb-2">LinkedIn</h3>
      <p class="text-slate-400 text-center font-medium group-hover:text-indigo-400 transition-colors">Let's connect professionally</p>
    </a>

    <!-- GitHub Card -->
    <a href="https://github.com/ibrahimnassar24" target="_blank" rel="noopener noreferrer" class="glass-card flex flex-col items-center p-10 rounded-3xl group hover:-translate-y-1 hover:shadow-[0_10px_40px_-10px_rgba(255,255,255,0.1)] transition-all duration-300">
      <div class="w-16 h-16 mb-6 rounded-2xl bg-slate-800/80 flex items-center justify-center border border-slate-700/50 text-slate-300 group-hover:bg-slate-700 group-hover:text-white transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
        </svg>
      </div>
      <h3 class="text-xl font-bold text-white mb-2">GitHub</h3>
      <p class="text-slate-400 text-center font-medium group-hover:text-slate-200 transition-colors">Check out my repositories</p>
    </a>

  </div>
</Layout>