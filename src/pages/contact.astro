---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Me" description="Contact information and professional social links.">
  <h1 class="text-4xl font-bold mb-10 border-b border-slate-800 pb-4">Contact Me</h1>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
    <div class="space-y-6">
      <p class="text-lg text-slate-300">I am currently based in Alexandria, Egypt, and I am open to full-stack web development and backend engineering roles.</p>
      
      <div class="space-y-4">
        <div class="flex items-center gap-4 text-slate-300">
          <span class="font-bold text-cyan-400 w-24">Email:</span>
          <a href="mailto:ebrahim24111990@gmail.com" class="hover:text-white transition-colors">ebrahim24111990@gmail.com</a>
        </div>
        <div class="flex items-center gap-4 text-slate-300">
          <span class="font-bold text-cyan-400 w-24">Phone:</span>
          <span>+201095466271</span>
        </div>
        <div class="flex items-center gap-4 text-slate-300">
          <span class="font-bold text-cyan-400 w-24">LinkedIn:</span>
          <a href="https://www.linkedin.com/in/ibrahim-nassar-5325ab236" target="_blank" class="hover:text-white transition-colors">Ibrahim Nassar</a>
        </div>
        <div class="flex items-center gap-4 text-slate-300">
          <span class="font-bold text-cyan-400 w-24">GitHub:</span>
          <a href="https://github.com/ibrahimnassar24" target="_blank" class="hover:text-white transition-colors">ibrahimnassar24</a>
        </div>
      </div>
    </div>
    
    <form class="space-y-4 bg-slate-900 p-6 rounded-xl border border-slate-800">
      <div>
        <label class="block text-sm font-medium text-slate-400 mb-1">Name</label>
        <input type="text" class="w-full bg-slate-950 border border-slate-700 rounded-lg px-4 py-2 text-slate-200 focus:outline-none focus:border-cyan-500" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-400 mb-1">Email</label>
        <input type="email" class="w-full bg-slate-950 border border-slate-700 rounded-lg px-4 py-2 text-slate-200 focus:outline-none focus:border-cyan-500" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-400 mb-1">Message</label>
        <textarea rows="4" class="w-full bg-slate-950 border border-slate-700 rounded-lg px-4 py-2 text-slate-200 focus:outline-none focus:border-cyan-500"></textarea>
      </div>
      <button type="submit" class="w-full bg-cyan-600 hover:bg-cyan-500 text-white font-bold py-2 px-4 rounded-lg transition-colors">
        Send Message
      </button>
    </form>
  </div>
</Layout>