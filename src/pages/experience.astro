---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Experience & Projects" description="Professional experience and full-stack development projects.">
  <h1 class="text-4xl font-bold mb-10 border-b border-slate-800 pb-4">Experience & Projects</h1>
  
  <div class="space-y-12">
    <!-- Professional Roles -->
    <section>
      <h2 class="text-2xl font-semibold text-cyan-400 mb-6">Work Experience</h2>
      <div class="space-y-6">
        <div class="p-6 bg-slate-900 rounded-xl border border-slate-800">
          <div class="flex justify-between items-start mb-2">
            <h3 class="text-xl font-bold">Backend .Net Developer</h3>
            <span class="text-sm text-slate-400">Oct 2025 - Present</span>
          </div>
          <p class="text-cyan-500 mb-4">@OPNsify</p>
          <ul class="list-disc list-inside text-slate-300 space-y-2">
            <li>Developing <strong>PowerOps</strong>: A cross-platform .NET 8.0 network monitoring and automation system featuring Clean Architecture.</li>
            <li>Building scalable <strong>ERP systems</strong> using .NET (C#), Entity Framework, and Angular with Domain-Driven Design.</li>
          </ul>
        </div>
        
        <div class="p-6 bg-slate-900 rounded-xl border border-slate-800">
          <div class="flex justify-between items-start mb-2">
            <h3 class="text-xl font-bold">IT & Web Developer / Supervisor</h3>
            <span class="text-sm text-slate-400">April 2023 - Present</span>
          </div>
          <p class="text-cyan-500 mb-4">Private School</p>
          <p class="text-slate-300">Managing IT infrastructure, educational technology, and web development initiatives.</p>
        </div>
      </div>
    </section>

    <!-- Projects -->
    <section>
      <h2 class="text-2xl font-semibold text-cyan-400 mb-6">Selected Projects</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="p-6 bg-slate-900 rounded-xl border border-slate-800">
          <h3 class="text-lg font-bold mb-2">Connect4 Multiplayer Game</h3>
          <p class="text-slate-300 text-sm">Developed a real-time multiplayer game with an ASP.NET Core Web API backend and Angular frontend, utilizing SignalR and Identity Framework.</p>
        </div>
        <div class="p-6 bg-slate-900 rounded-xl border border-slate-800">
          <h3 class="text-lg font-bold mb-2">Messaging App (Nest.js)</h3>
          <p class="text-slate-300 text-sm">Engineered a real-time event pipeline using WebSockets, Redis Pub/Sub, and RabbitMQ. Optimized persistence with PostgreSQL and MongoDB.</p>
        </div>
        <div class="p-6 bg-slate-900 rounded-xl border border-slate-800">
          <h3 class="text-lg font-bold mb-2">OCR App</h3>
          <p class="text-slate-300 text-sm">Application to convert scanned PDFs into Word documents and generate audio records using Google Vision AI and Google TTS.</p>
        </div>
      </div>
    </section>
  </div>
</Layout>