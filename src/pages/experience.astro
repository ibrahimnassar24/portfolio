---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<Layout title="Experience" description="Professional experience of Ibrahim Nassar.">
  
  <PageHeader 
    title="Work Experience"
    description="A timeline of my professional journey, focusing on developing scalable backend architectures and robust full-stack solutions."
    lineColor="bg-cyan-500"
  />

  <div class="space-y-24">
    
    <!-- Professional Roles -->
    <section class="animate-fade-up" style="animation-delay: 100ms;">
      <div class="relative border-l border-slate-800 ml-3 space-y-12">
        
        <!-- OPNsify -->
        <div class="relative pl-8">
          <div class="absolute -left-1.5 top-1.5 w-3 h-3 bg-cyan-500 rounded-full shadow-[0_0_10px_rgba(6,182,212,0.8)] ring-4 ring-slate-950"></div>
          <div class="glass-card p-6 md:p-8 rounded-2xl group">
            <div class="flex flex-col md:flex-row md:justify-between md:items-start mb-4 gap-2">
              <div>
                <h3 class="text-xl font-bold text-white group-hover:text-cyan-400 transition-colors">Backend .NET Developer</h3>
                <p class="text-cyan-500 font-medium">@OPNsify</p>
              </div>
              <span class="inline-flex items-center px-3 py-1 rounded-full bg-slate-800/50 border border-slate-700 text-sm text-slate-300 whitespace-nowrap">
                Oct 2023 - Present
              </span>
            </div>
            
            <div class="space-y-4 mt-6">
              <div class="bg-slate-900/50 rounded-lg p-4 border border-white/5">
                <h4 class="text-white font-semibold mb-2">PowerOps</h4>
                <p class="text-slate-300 text-sm leading-relaxed">
                  Developed a cross-platform .NET network monitoring and automation system featuring a custom TCP protocol, Clean Architecture, and multi-hypervisor (ESXi) integration to automate enterprise infrastructure management.
                </p>
              </div>
              
              <div class="bg-slate-900/50 rounded-lg p-4 border border-white/5">
                <h4 class="text-white font-semibold mb-2">ERP System</h4>
                <p class="text-slate-300 text-sm leading-relaxed">
                  Built a scalable ERP system using .NET (C#), Entity Framework, and Angular following Domain-Driven Design and Clean Architecture. Implemented RESTful APIs, role-based access control, and applied Repository/Unit of Work patterns.
                </p>
              </div>
            </div>
          </div>
        </div>
        
      </div>
    </section>

  </div>
</Layout>