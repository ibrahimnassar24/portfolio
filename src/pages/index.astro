---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Home" 
  description="Portfolio of Ibrahim Nassar, a Full-Stack Web Developer proficient in React, Angular, Node.js, and .NET Core."
>
  <section class="flex flex-col items-center justify-center min-h-[70vh] text-center space-y-8">
    <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight">
      Welcome, I'm <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-600">Ibrahim Nassar</span>
    </h1>
    <h2 class="text-2xl md:text-3xl font-medium text-slate-400">
      Back-End / Full-Stack Web Developer
    </h2>
    <p class="max-w-2xl text-lg text-slate-300 leading-relaxed">
      Self-driven Web Developer with a Full Stack Nanodegree from Udacity, passionate about mastering software fundamentals. Proficient in both front-end (React, Angular) and back-end (Node.js, .NET Core) development, with a solid foundation in database management and cloud technologies.
    </p>
    <div class="flex gap-4 pt-4">
      <a href="/contact" class="px-6 py-3 bg-cyan-600 hover:bg-cyan-500 text-white rounded-lg font-semibold transition-all">Get in Touch</a>
      <a href="/experience" class="px-6 py-3 bg-slate-800 hover:bg-slate-700 text-white rounded-lg font-semibold transition-all border border-slate-700">View Projects</a>
    </div>
  </section>
</Layout>