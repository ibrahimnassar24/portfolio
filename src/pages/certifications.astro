---
import Layout from '../layouts/Layout.astro';

const certs = [
  { name: "Advanced Full-Stack Web Development Nanodegree", issuer: "Udacity", year: "2023" },
  { name: "Professional Front-End Web Development", issuer: "Udacity", year: "2023" },
  { name: "Egypt FWD Scholarship Graduate Track", issuer: "Egypt FWD", year: "2022" },
  { name: "Foundational C#", issuer: "Microsoft", year: "" },
  { name: "Google Cloud Platform Professional Developer", issuer: "Google", year: "" }
];
---

<Layout title="Certifications" description="Professional certifications and education history.">
  <h1 class="text-4xl font-bold mb-10 border-b border-slate-800 pb-4">Certifications & Education</h1>
  <div class="space-y-4">
    {certs.map(cert => (
      <div class="flex justify-between items-center p-5 bg-slate-900 border border-slate-800 rounded-xl hover:border-slate-600 transition-colors">
        <div>
          <h3 class="font-bold text-lg text-slate-200">{cert.name}</h3>
          <p class="text-cyan-500">{cert.issuer}</p>
        </div>
        {cert.year && <span class="text-slate-400 bg-slate-950 px-3 py-1 rounded border border-slate-800">{cert.year}</span>}
      </div>
    ))}
  </div>
</Layout>