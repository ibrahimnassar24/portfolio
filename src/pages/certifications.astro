---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';

const certs = [
  { 
    name: "Advanced Full-Stack Web Development Nanodegree", 
    issuer: "Udacity", 
    year: "2023",
    type: "certification"
  },
  { 
    name: "Professional Front-End Web Development", 
    issuer: "Udacity", 
    year: "2022", // Updated based on CV
    type: "certification"
  },
  { 
    name: "Egypt FWD Scholarship Graduate Track", 
    issuer: "Egypt FWD", 
    year: "2022",
    type: "education"
  },
  { 
    name: "Foundational C#", 
    issuer: "Microsoft", 
    year: "",
    type: "certification"
  },
  { 
    name: "Google Cloud Platform Professional Developer", 
    issuer: "Google", 
    year: "",
    type: "certification"
  }
];

const courses = [
  { name: "Fundamentals of Red Hat Enterprise Linux" },
  { name: "CCNA (Jeremy's IT Lab)" }
];
---

<Layout title="Certifications" description="Professional certifications and education history of Ibrahim Nassar.">
  
  <PageHeader 
    title="Certifications"
    subtitle="& Education"
    description="A record of my formal education, professional certifications, and continuous self-learning initiatives."
    lineColor="bg-cyan-500"
  />

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 animate-fade-up" style="animation-delay: 100ms;">
    
    <!-- Main Certifications Timeline -->
    <div class="lg:col-span-2 space-y-6">
      <h2 class="text-2xl font-semibold text-white mb-6 flex items-center gap-3 border-b border-slate-800 pb-4">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-cyan-400">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
        </svg>
        Degrees & Certifications
      </h2>
      
      <div class="space-y-4">
        {certs.map((cert) => (
          <div class="glass-card flex flex-col sm:flex-row sm:items-center justify-between p-5 md:p-6 rounded-xl hover:border-cyan-500/30 transition-all group">
            <div class="flex items-start gap-4">
              <div class="hidden sm:flex mt-1 p-2 rounded-lg bg-slate-800/50 border border-slate-700">
                {cert.type === 'education' ? (
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-indigo-400">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.315 48.315 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75Z" />
                  </svg>
                ) : (
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-cyan-400">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
                  </svg>
                )}
              </div>
              <div>
                <h3 class="font-bold text-lg text-white group-hover:text-cyan-300 transition-colors">{cert.name}</h3>
                <p class="text-slate-400 mt-1 font-medium">{cert.issuer}</p>
              </div>
            </div>
            {cert.year && (
              <div class="mt-4 sm:mt-0 sm:ml-4 shrink-0">
                <span class="inline-flex items-center px-3 py-1 rounded-md bg-slate-900 border border-slate-700 text-sm font-medium text-slate-300">
                  {cert.year}
                </span>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Courses Sidebar -->
    <div class="space-y-6">
      <h2 class="text-2xl font-semibold text-white mb-6 flex items-center gap-3 border-b border-slate-800 pb-4">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-emerald-400">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
        </svg>
        Courses & Self-Study
      </h2>
      
      <div class="glass-card p-6 rounded-2xl">
        <ul class="space-y-4">
          {courses.map(course => (
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-emerald-500 shrink-0 mt-0.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
              </svg>
              <span class="text-slate-300 font-medium">{course.name}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
    
  </div>
</Layout>